{
  "version": 1,
  "_comment": "Small-talk паттерны. match_type: exact_word | exact_phrase | contains. Редактируй и зови /reload_responses в Telegram чтобы перезагрузить без рестарта бота.",
  "patterns": [
    {
      "_label": "приветствия",
      "match_type": "exact_word",
      "match": ["привет", "приветствую", "здарова", "здорова", "здравствуй", "здравствуйте", "хай", "хелло", "хеллоу", "салют", "салам", "ку", "куку", "yo", "hi", "hello"],
      "responses": [
        "Привет! Чем могу помочь?",
        "Здарова! Я на связи.",
        "Хай! Что у тебя?",
        "Привет 👋 Слушаю."
      ]
    },
    {
      "_label": "как дела",
      "match_type": "exact_phrase",
      "match": ["как дела", "как сам", "как ты", "как жизнь", "че как", "че как жизнь", "что нового", "как сам как сама", "как поживаешь", "как делишки"],
      "responses": [
        "Норм, работаю. У тебя как?",
        "Всё под контролем 🙂",
        "Бодрячком, готов помогать.",
        "Жив-здоров, на боевом посту.",
        "Лучше всех, чё там у тебя?"
      ]
    },
    {
      "_label": "благодарность",
      "match_type": "exact_word",
      "match": ["спасибо", "спс", "пасиб", "благодарю", "благодарствую", "thanks", "thx"],
      "responses": [
        "Не за что!",
        "Всегда пожалуйста.",
        "Обращайся.",
        "Да брось, для этого и нужен."
      ]
    },
    {
      "_label": "прощание",
      "match_type": "exact_word",
      "match": ["пока", "бывай", "досвидания", "досвидос", "увидимся", "до встречи", "до связи", "bye", "goodbye", "чао"],
      "responses": [
        "Пока!",
        "Бывай 👋",
        "До связи.",
        "Увидимся."
      ]
    },
    {
      "_label": "подтверждение",
      "match_type": "exact_phrase",
      "match": ["ок", "окей", "хорошо", "ладно", "понял", "поняла", "понятно", "ясно", "принято"],
      "responses": [
        "👌",
        "Принял.",
        "Окей.",
        "Хорошо, тогда жду следующее."
      ]
    },
    {
      "_label": "тест",
      "match_type": "exact_phrase",
      "match": ["тест", "test", "проверка", "1", "раз раз", "раз два три"],
      "responses": [
        "На связи 🟢",
        "Слышу.",
        "Работаю."
      ]
    }
  ]
}
