async def _run_cmd(args: list[str], cwd: str | None = None, timeout: int = 60) -> tuple[int, str, str]:
    """Запуск subprocess argv-form, timeout."""
    try:
        proc = await asyncio.create_subprocess_exec(
            *args,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
            cwd=cwd,
        )
        try:
            sout, serr = await asyncio.wait_for(proc.communicate(), timeout=timeout)
        except asyncio.TimeoutError:
            proc.kill()
            await proc.wait()
            return 124, "", f"TIMEOUT {timeout}s"
        return proc.returncode or 0, sout.decode("utf-8", errors="replace"), serr.decode("utf-8", errors="replace")
    except Exception as e:
        return -1, "", f"subprocess error: {e}"


