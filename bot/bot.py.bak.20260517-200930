# ============================================================
# Bug 6 fix (2026-05-17): Markdown → Telegram-safe HTML
# Модели часто выдают `###`, `**`, `` ` ``, ` ``` ` — Telegram с parse_mode=HTML
# рендерит их литералами. Конвертим в <b>/<i>/<code>/<pre>/<a> перед отправкой.
# ============================================================
def md_to_tg_html(text: str) -> str:
    if not text:
        return text
    import html as _html
    import re as _re

    # 1. Сначала вырезаем fenced code-блоки (```...```) в plain placeholders,
    # чтобы их содержимое не схлопнули нижестоящие правила inline-форматирования.
    placeholders: list[str] = []

    def _stash_code(match: "_re.Match[str]") -> str:
        body = match.group(1)
        placeholders.append(f"<pre><code>{_html.escape(body)}</code></pre>")
        return f"\x00CB{len(placeholders) - 1}\x00"

    text = _re.sub(r"```(?:[a-zA-Z0-9_+\-]*)\n?(.*?)```", _stash_code, text, flags=_re.DOTALL)

    # 2. inline-код `...`
    def _stash_inline(match: "_re.Match[str]") -> str:
        body = match.group(1)
        placeholders.append(f"<code>{_html.escape(body)}</code>")
        return f"\x00CB{len(placeholders) - 1}\x00"

    text = _re.sub(r"`([^`\n]+)`", _stash_inline, text)

    # 3. HTML-escape всего остального текста (вне placeholder'ов)
    text = _html.escape(text)

    # 4. Заголовки  #..###### → <b>...</b>
    text = _re.sub(r"^[ \t]{0,3}#{1,6}[ \t]+(.+?)[ \t]*#*[ \t]*$", r"<b>\1</b>", text, flags=_re.MULTILINE)

    # 5. Bold **text** / __text__ → <b>
    text = _re.sub(r"\*\*([^*\n]+?)\*\*", r"<b>\1</b>", text)
    text = _re.sub(r"(?<!_)__([^_\n]+?)__(?!_)", r"<b>\1</b>", text)

    # 6. Italic *text* / _text_ → <i>  (без захвата ** / __)
    text = _re.sub(r"(?<!\*)\*(?!\*)([^*\n]+?)(?<!\*)\*(?!\*)", r"<i>\1</i>", text)
    text = _re.sub(r"(?<!_)_(?!_)([^_\n]+?)(?<!_)_(?!_)", r"<i>\1</i>", text)

    # 7. Ссылки [text](url) → <a href="url">text</a>
    def _link(match: "_re.Match[str]") -> str:
        label = match.group(1)
        url = match.group(2)
        # url был escapen на шаге 3, вернём амперсанд
        url = url.replace("&amp;", "&")
        return f'<a href="{url}">{label}</a>'

    text = _re.sub(r"\[([^\]]+)\]\(([^)\s]+)\)", _link, text)

    # 8. Возвращаем code-плейсхолдеры обратно
    def _restore(match: "_re.Match[str]") -> str:
        idx = int(match.group(1))
        return placeholders[idx]

    text = _re.sub(r"\x00CB(\d+)\x00", _restore, text)
    return text


def strip_tool_call_leaks(text: str) -> str:
    """Удаляет orphan tool-call JSON, который модель не вызвала, а вывалила
    в plain text как часть ответа (lpr-symptom: «Пример Поиска: {"name": ...}»).
    Покрывает: fenced ``` { "name": ... } ```, голый { "name": "...", "arguments": ... }.
    """
    import re as _re

    # Fenced JSON блок с "name"
    text = _re.sub(
        r"```(?:json)?\s*\{\s*\"name\"\s*:.*?\}\s*```",
        "",
        text,
        flags=_re.DOTALL | _re.IGNORECASE,
    )
    # Голый top-level JSON tool-call (упрощённо: balanced до 2 уровней)
    text = _re.sub(
        r"\{\s*\"name\"\s*:\s*\"[A-Za-z_][A-Za-z0-9_]*\"\s*,\s*\"arguments\"\s*:\s*\{(?:[^{}]|\{[^{}]*\})*\}\s*\}",
        "",
        text,
        flags=_re.DOTALL,
    )
    # Уберём лишние пустые строки от вырезов
    text = _re.sub(r"\n{3,}", "\n\n", text).strip()
    return text


# ============================================================
# DB singleton — переиспользуемое соединение (perf-boost 2026-05-16)
# Один connection вместо 6-10 connect/close per request. WAL mode + lock.
# ============================================================
_db_singleton: aiosqlite.Connection | None = None
_db_lock = asyncio.Lock()

# Кэш admin status (TTL=60s) — admin status не меняется минутами
_admin_cache: dict[int, tuple[float, bool]] = {}
_ADMIN_CACHE_TTL = 60.0


async def _get_db() -> aiosqlite.Connection:
    """Singleton aiosqlite connection. Lazy init."""
    global _db_singleton
    if _db_singleton is not None:
        return _db_singleton
    async with _db_lock:
        if _db_singleton is None:
            _db_singleton = await aiosqlite.connect(DB_PATH)
            await _db_singleton.execute("PRAGMA journal_mode=WAL;")
            await _db_singleton.execute("PRAGMA foreign_keys=ON;")
            await _db_singleton.execute("PRAGMA synchronous=NORMAL;")
            await _db_singleton.commit()
            log.info("DB singleton initialized: %s (WAL)", DB_PATH)
    return _db_singleton


async def _db_close():
    """Закрыть singleton при shutdown."""
    global _db_singleton
    if _db_singleton is not None:
        await _db_singleton.close()
        _db_singleton = None


