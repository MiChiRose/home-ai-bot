# Pending checkouts: user_id → {sha, expires_at}
_PENDING_CHECKOUTS: dict[int, dict] = {}


@dp.message(Command("git_checkout"))
async def git_checkout_handler(msg: Message):
    if not await db_is_admin(msg.from_user.id):
        return await msg.answer("⛔ Только админ.")
    if not _is_git_repo():
        return await msg.answer("❌ Не git-репо.")
    args = (msg.text or "").split(maxsplit=1)
    if len(args) < 2 or not args[1].strip():
        return await msg.answer("Использование: <code>/git_checkout &lt;sha&gt;</code>\nПотом подтверди /confirm_checkout &lt;sha&gt;")
    sha = args[1].strip()
    rc, head_check, _ = await _run_cmd(["git", "rev-parse", sha], cwd=str(ROOT), timeout=10)
    if rc != 0:
        return await msg.answer(f"❌ Неизвестный commit: {sha}")
    rc, log_one, _ = await _run_cmd(["git", "log", "-1", "--format=%h %s (%an)", sha], cwd=str(ROOT), timeout=10)
    _PENDING_CHECKOUTS[msg.from_user.id] = {"sha": sha, "expires_at": time.time() + 60}
    await msg.answer(
        f"⚠️ <b>Готовлю checkout</b>\n"
        f"Target: <code>{log_one.strip()}</code>\n\n"
        f"Это сделает <code>git reset --hard {sha[:8]}</code> + рестарт бота.\n"
        f"Подтверди в течение 60 сек: <code>/confirm_checkout {sha[:8]}</code>"
    )


@dp.message(Command("confirm_checkout"))
async def confirm_checkout_handler(msg: Message):
    if not await db_is_admin(msg.from_user.id):
        return await msg.answer("⛔ Только админ.")
    args = (msg.text or "").split(maxsplit=1)
    if len(args) < 2:
        return await msg.answer("Использование: <code>/confirm_checkout &lt;sha_prefix&gt;</code>")
    sha_prefix = args[1].strip()
    pending = _PENDING_CHECKOUTS.get(msg.from_user.id)
    if not pending:
        return await msg.answer("❌ Нет pending checkout'а. Сначала /git_checkout <sha>")
    if time.time() > pending["expires_at"]:
        _PENDING_CHECKOUTS.pop(msg.from_user.id, None)
        return await msg.answer("⏱ Pending checkout протух")
    if not pending["sha"].startswith(sha_prefix):
        return await msg.answer(f"❌ SHA не совпадает: жду <code>{pending['sha'][:8]}…</code>")
    _PENDING_CHECKOUTS.pop(msg.from_user.id, None)
    rc, out, err = await _run_cmd(["git", "reset", "--hard", pending["sha"]], cwd=str(ROOT), timeout=30)
    if rc != 0:
        return await msg.answer(f"❌ git reset упал rc={rc}\n<pre>{err[:1000]}</pre>")
    await msg.answer(f"✅ Checkout сделан: <code>{pending['sha'][:8]}</code>\nЗапускаю рестарт сервиса…")
    unit_name = os.environ.get("BOT_SYSTEMD_UNIT", "home-ai-bot.service")
    # restart через отдельный fire-and-forget — иначе бот убьёт сам себя до отправки
    await asyncio.create_subprocess_exec(
        "bash", "-c", f"sleep 1 && systemctl --user restart {unit_name}",
        stdout=asyncio.subprocess.DEVNULL,
        stderr=asyncio.subprocess.DEVNULL,
