# P5: remote ops — self-update механизм через Telegram
# ============================================================
# In-memory pending updates с TTL 60 сек. Не persistent — после рестарта обнуляется
# чтобы случайно не выполнился старый pending скрипт.
_PENDING_UPDATES: dict[int, dict] = {}
PENDING_TTL_SEC = 60
UPDATE_TIMEOUT_SEC = 300
UPDATES_DIR = ROOT / "updates"
BACKUPS_DIR = ROOT / "backups"
AUDIT_LOG = ROOT / "data" / "admin-actions.log"
MAX_TAIL_LINES = 30


def _audit(user_id: int, action: str, **fields) -> None:
    AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)
    ts = datetime.now(timezone.utc).isoformat()
    parts = [f"ts={ts}", f"user_id={user_id}", f"action={action}"]
    for k, v in fields.items():
        parts.append(f"{k}={v}")
    with open(AUDIT_LOG, "a", encoding="utf-8") as f:
        f.write(" ".join(parts) + "\n")


def _sha256_file(p: Path) -> str:
    h = hashlib.sha256()
    with open(p, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def _make_backup() -> Path:
    """Tar -czf project (без .venv/updates/backups/, sqlite через отдельный .backup snapshot)."""
    BACKUPS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    tar_path = BACKUPS_DIR / f"backup-{stamp}.tar.gz"
    def _filter(tarinfo: tarfile.TarInfo):
        skip = (".venv", "updates", "backups", "data/bot.db", "data/bot.db-wal",
                "data/bot.db-shm", "__pycache__", ".pytest_cache", ".git")
        if any(s in tarinfo.name for s in skip):
            return None
        return tarinfo
    with tarfile.open(tar_path, "w:gz") as t:
        t.add(str(ROOT), arcname=ROOT.name, filter=_filter)
    if DB_PATH.exists():
        db_backup = BACKUPS_DIR / f"bot-db-{stamp}.sqlite"
        # argv-form, не shell=True — безопасно
        subprocess.run(
            ["sqlite3", str(DB_PATH), f".backup '{db_backup}'"],
            check=False, timeout=30,
        )
    return tar_path


async def _rollback_from_backup(backup_path: Path) -> tuple[bool, str]:
    log_lines: list[str] = [f"Rollback from: {backup_path}"]
    try:
        with tarfile.open(backup_path, "r:gz") as t:
            t.extractall(path=str(ROOT.parent))
        log_lines.append("✅ tar.gz распакован")
        return True, "\n".join(log_lines)
    except Exception as e:
        log_lines.append(f"✗ Rollback FAILED: {e}")
        return False, "\n".join(log_lines)


async def _run_update_script(script_path: Path) -> tuple[int, str, str]:
    """Запуск bash-скрипта в argv-form (НЕ shell=True). Timeout по wait_for."""
    try:
        proc = await asyncio.create_subprocess_exec(
            "bash", str(script_path),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE,
            cwd=str(ROOT),
        )
        try:
            stdout_b, stderr_b = await asyncio.wait_for(
                proc.communicate(), timeout=UPDATE_TIMEOUT_SEC
            )
        except asyncio.TimeoutError:
            proc.kill()
            await proc.wait()
            return 124, "", f"TIMEOUT после {UPDATE_TIMEOUT_SEC} секунд"
        return proc.returncode or 0, stdout_b.decode("utf-8", errors="replace"), stderr_b.decode("utf-8", errors="replace")
    except Exception as e:
        return -1, "", f"subprocess error: {e}"


def _tail(text: str, n: int = MAX_TAIL_LINES) -> str:
    lines = text.splitlines()
    return "\n".join(lines[-n:]) if len(lines) > n else text


@dp.message(Command("confirm_update"))
async def confirm_update_handler(msg: Message):
    user_id = msg.from_user.id
    if not await db_is_admin(user_id):
        return await msg.answer("⛔ Только админ.")
    args = (msg.text or "").split(maxsplit=1)
    if len(args) < 2 or not args[1].strip():
        return await msg.answer("Использование: <code>/confirm_update &lt;sha_prefix&gt;</code>")
    sha_prefix = args[1].strip()

    pending = _PENDING_UPDATES.get(user_id)
    if not pending:
        return await msg.answer("❌ Нет pending update'а. Кинь .sh файл <code>update-*.sh</code>")
    if time.time() > pending["expires_at"]:
        _PENDING_UPDATES.pop(user_id, None)
        return await msg.answer("⏱ Pending update протух (>60 сек). Кинь файл заново.")
    if not pending["sha"].startswith(sha_prefix):
        return await msg.answer(f"❌ SHA не совпадает. Жду <code>{pending['sha'][:8]}…</code>")

    _PENDING_UPDATES.pop(user_id, None)
    script_path = Path(pending["path"])
    script_name = pending["name"]
    sha = pending["sha"]

    await msg.answer(f"🔧 Бэкаплю проект перед запуском <code>{script_name}</code>…")
    _audit(user_id, "update_start", sha=sha[:12], name=script_name)

    try:
        backup_path = _make_backup()
    except Exception as e:
        log.exception("backup failed: %s", e)
        _audit(user_id, "update_aborted", reason="backup_failed", err=str(e)[:80])
        return await msg.answer(f"❌ Backup упал: {e}\nUpdate отменён.")

    await msg.answer(f"📦 Backup: <code>{backup_path.name}</code>. Запускаю (max {UPDATE_TIMEOUT_SEC} сек)…")

    rc, stdout, stderr = await _run_update_script(script_path)
    combined_log = f"=== STDOUT ===\n{stdout}\n=== STDERR ===\n{stderr}"

    log_file = UPDATES_DIR / "done" / f"{sha[:12]}-{int(time.time())}.log"
    log_file.parent.mkdir(parents=True, exist_ok=True)
    log_file.write_text(combined_log, encoding="utf-8")

    from aiogram.types import FSInputFile as _FSInputFile

    if rc == 0:
        _audit(user_id, "update_success", sha=sha[:12], rc=rc)
        try:
            shutil.move(str(script_path), str(UPDATES_DIR / "done" / script_path.name))
        except Exception:
            pass
        await msg.answer(
            f"✅ <b>Обновление успешно</b> (rc=0)\n"
            f"Backup: <code>{backup_path.name}</code>\n\n"
            f"<pre>{_tail(stdout, 15)[:1500]}</pre>"
        )
        try:
            await msg.answer_document(_FSInputFile(str(log_file)))
        except Exception:
            pass
    else:
        _audit(user_id, "update_failed", sha=sha[:12], rc=rc)
        try:
            shutil.move(str(script_path), str(UPDATES_DIR / "failed" / script_path.name))
        except Exception:
            pass
        await msg.answer(f"🔥 <b>Скрипт упал rc={rc}</b>. Делаю rollback из <code>{backup_path.name}</code>…")
        rollback_ok, rollback_log = await _rollback_from_backup(backup_path)
        rb_file = UPDATES_DIR / "failed" / f"rollback-{sha[:12]}-{int(time.time())}.log"
        rb_file.write_text(rollback_log, encoding="utf-8")
        _audit(user_id, "rollback", sha=sha[:12], success=rollback_ok)
        if rollback_ok:
            unit_name = os.environ.get("BOT_SYSTEMD_UNIT", "home-ai-bot.service")
            await msg.answer(
                f"♻️ Rollback успешен. Для надёжности рестарт сервиса:\n"
                f"<code>systemctl --user restart {unit_name}</code>"
            )
        else:
            await msg.answer(
                f"⚠️ <b>Rollback ТОЖЕ упал.</b> Проверь руками: <code>{backup_path}</code>."
            )
        try:
            await msg.answer_document(_FSInputFile(str(log_file)))
            await msg.answer_document(_FSInputFile(str(rb_file)))
        except Exception:
            pass


