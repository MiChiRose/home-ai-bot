                "- Если web_search не нашёл нужного / недоступен / упал — честно скажи «не смог найти актуальные данные сейчас», БЕЗ перечисления сайтов для самостоятельного поиска.\n"
                "- Никогда не вставляй сырой tool-call JSON (`{\"name\": ..., \"arguments\": ...}`) в финальный ответ юзеру — это служебный формат, юзер его не должен видеть.\n"
                "- НЕ объявляй процесс работы. Запрещены фразы вида «сейчас поищу в интернете», «выполню поиск», «обращусь к web_search», «проверю на сайте». Юзеру нужен СРАЗУ результат, а не описание твоих действий. Молча вызывай tool, молча получай данные, отдавай готовый ответ.\n\n"
                "ФОРМАТ ОТВЕТА:\n"
                "- Не используй Markdown-заголовки (`###`, `##`) — пиши обычным текстом, выделяй жирным `**...**` только важное.\n"
                "- Списки — обычные строки с дефисом или цифрой.\n\n"
                "ПО СОДЕРЖАНИЮ:\n"
                "- Отвечай кратко и по делу.\n"
                "- Если не знаешь и инструменты не помогли — честно скажи «не знаю», не выдумывай.\n\n"
                + ("ПЕРСОНАЛЬНЫЙ ПРОФИЛЬ ЮЗЕРА (вкладывается всегда, учитывай при ответе):\n" + user_profile if user_profile else "")
            ),
        }
        # Bug 2 fix (2026-05-17): hardcode ru — добавляем явный язык-маркер
        # к user message чтобы модель не дрейфовала в китайский / английский
        # при пустой истории. В history записывается оригинал user_text.
        user_text_for_llm = user_text + "\n\n[ВНИМАНИЕ: ответ строго на русском языке, без иероглифов и иностранных слов.]"
        messages_for_llm = [system] + history + [{"role": "user", "content": user_text_for_llm}]

        # 4) Вызываем модель
        # P2: для ветки `instruct` идём через tool-loop (web_search + file ops).
        # Для `coder` и `vl` — прямой ollama_chat без инструментов (там они не нужны
        # и vision-модели Hermes-tool format обычно не понимают).
        try:
            if final_choice == "instruct" and not image_b64:
                # P2: используем TOOLS_MODEL из .env (специально для tool calling — qwen2.5),
                # а не chosen_model (=MODEL_INSTRUCT, обычно gemma4 которая Hermes tool format не умеет).
                tools_model = os.environ.get("TOOLS_MODEL") or chosen_model
                response_text, _ = await chat_with_tools(
                    user_text_for_llm,
                    history,
                    model=tools_model,
                    ollama_url=OLLAMA_URL,
                    system_prompt=system["content"],
                )
                meta = {}
            else:
                response_text, meta = await ollama_chat(
                    chosen_model,
                    messages_for_llm,
                    images=[image_b64] if image_b64 else None,
                )
        except httpx.TimeoutException:
            await msg.answer("⏱ Ollama не ответила в течение тайм-аута. Попробуй ещё раз.")
            await _react(msg, "😢")
            return
        except Exception as e:
            log.exception("ollama call failed: %s", e)
            await msg.answer(f"❌ Ошибка модели: {e}")
            await _react(msg, "😢")
            return

        duration_ms = int((time.monotonic() - start_ts) * 1000)
        tokens_in = meta.get("prompt_eval_count") or 0
        tokens_out = meta.get("eval_count") or 0

        # 5) Отправляем ответ — через edit progress-message (или fallback delete+answer)
        final_text = response_text.strip() or "(пустой ответ от модели)"
        TG_MAX = 4096  # Telegram message limit

        async def _delete_progress():
            if progress_msg_id is None:
                return
            try:
                await bot.delete_message(msg.chat.id, progress_msg_id)
            except Exception:
                pass

        # Bug 1 fix (2026-05-17): убран edit_message_text — Telegram не шлёт
        # push-уведомление на edit, и юзер не понимает что ответ готов.
        # Всегда удаляем placeholder и шлём финальный ответ новым сообщением.
        # Bug 5+6 fix (2026-05-17): strip orphan tool-call JSON + markdown→HTML
        # перед отправкой (parse_mode=HTML в DefaultBotProperties).
        await _delete_progress()
        final_text = md_to_tg_html(strip_tool_call_leaks(final_text))
        if len(final_text) <= TG_MAX:
            await msg.answer(final_text)
        else:
            # Telegram lim 4096 — режем на чанки по 4000
            for i in range(0, len(final_text), 4000):
                await msg.answer(final_text[i:i + 4000])

        await _react(msg, "🎉" if response_text.strip() else "😢")

        # P3: document handling — если модель создала docx в sandbox/output/,
        # отправляем файл юзеру.
        try:
            from pathlib import Path as _Path
            from aiogram.types import FSInputFile as _FSInputFile
            sandbox = _Path(os.environ.get("BOT_SANDBOX", str(_Path.home() / "bot-workspace")))
            output_dir = sandbox / "output"
            if output_dir.exists():
                for docx_file in output_dir.glob("*.docx"):
                    # Отправляем только файлы созданные в текущем запросе (последние 60 сек)
                    if time.time() - docx_file.stat().st_mtime < 60:
                        try:
                            await msg.answer_document(_FSInputFile(str(docx_file)))
                            log.info("sent docx to user: %s", docx_file)
                        except Exception as e:
                            log.warning("send docx failed: %s", e)
                # P3b: image auto-send — сгенерированные PNG из ComfyUI
                for png_file in output_dir.glob("*.png"):
                    if time.time() - png_file.stat().st_mtime < 60:
                        try:
                            await msg.answer_photo(_FSInputFile(str(png_file)))
                            log.info("sent png to user: %s", png_file)
                        except Exception as e:
                            log.warning("send png failed: %s", e)
        except Exception as e:
            log.warning("docx auto-send check failed: %s", e)

        # 6) Сохраняем outgoing + статистику
        await db_record_message(
            user_id,
            "out",
            "assistant",
            response_text,
            model=chosen_model,
            tokens_in=tokens_in,
            tokens_out=tokens_out,
            duration_ms=duration_ms,
        )
        await db_incr_usage(user_id, tokens_in, tokens_out)

    await inference_queue.put(process)


# ============================================================
# main
# ============================================================
async def main():
    await db_init()
    await _get_db()  # инициализируем singleton + WAL
    await db_lifecycle("start", {"pid": os.getpid()})
    log.info("Bot starting. Admins: %s. Ollama: %s", ADMIN_IDS, OLLAMA_URL)

    # Pre-warm Ollama: грузим основные модели в VRAM при старте,
    # чтобы первое сообщение пользователя летело без cold-load 30-60 сек
    async def _prewarm():
        tools_model = os.environ.get("TOOLS_MODEL") or MODEL_ROUTER or MODEL_INSTRUCT
        log.info("pre-warming Ollama model: %s", tools_model)
        try:
            async with httpx.AsyncClient(timeout=120) as client:
                await client.post(
                    f"{OLLAMA_URL}/api/generate",
                    json={"model": tools_model, "prompt": "hi", "stream": False, "keep_alive": -1, "options": {"num_predict": 3}},
                )
            log.info("pre-warm done")
        except Exception as e:
            log.warning("pre-warm failed: %s (бот всё равно работает, просто первое сообщение будет холодным)", e)

    prewarm_task = asyncio.create_task(_prewarm())

    # Запускаем worker'а
    worker = asyncio.create_task(inference_worker())

    try:
        # === apply_command auto-inject ===
        register_apply_handler(dp, bot, [int(x) for x in os.environ.get('BOT_ADMIN_IDS', '').split(',') if x.strip()])
        register_startup_notice(dp, bot)
        # === features_pack auto-inject ===
        setup_feature_pack(dp, bot, [int(x) for x in os.environ.get('BOT_ADMIN_IDS', '').split(',') if x.strip()])
        await dp.start_polling(bot, allowed_updates=dp.resolve_used_update_types())
    finally:
        worker.cancel()
        await db_lifecycle("stop")
        await _db_close()
        log.info("Bot stopped.")



# === ERROR_REPORTER_BLOCK ===
# Глобальный error-handler: ловит unhandled exceptions из любого хэндлера
# и шлёт админу полный traceback с контекстом. Установлен setup-error-reporter.sh.

@dp.errors()
async def _error_to_admin(event: ErrorEvent):
    try:
        exc = event.exception
        update = event.update
        msg = getattr(update, "message", None) or getattr(update, "callback_query", None)
        if hasattr(msg, "message"):  # CallbackQuery -> message
            msg = msg.message
        user = getattr(msg, "from_user", None) if msg else None
        user_id = user.id if user else "?"
        user_name = (user.full_name if user else "") or ""
        user_uname = ("@" + user.username) if (user and user.username) else ""
        orig_text = ""
        if msg is not None:
            orig_text = (msg.text or msg.caption or "<no text>")
        orig_short = orig_text[:400] + ("…" if len(orig_text) > 400 else "")

        tb_full = "".join(traceback.format_exception(type(exc), exc, exc.__traceback__))
        summary = f"{type(exc).__name__}: {exc}"

        text = (
            "🐞 Ошибка в боте\n\n"
            f"👤 {user_name} {user_uname} (id: {user_id})\n"
            f"💬 Запрос: {orig_short}\n"
            f"🪲 {summary}"
        )

        fname = f"traceback-{user_id}-{int(time.time())}.txt"
        doc = BufferedInputFile(tb_full.encode("utf-8"), filename=fname)

        # ADMIN_USER_IDS может быть list[int] или set[int]; конвертим в iterable
        try:
            _admins = list(ADMIN_USER_IDS)  # type: ignore[name-defined]
        except NameError:
            _admins = []
        for admin_id in _admins:
            try:
                await bot.send_message(admin_id, text)
                await bot.send_document(admin_id, doc)
            except Exception:
                pass

        if msg is not None and hasattr(msg, "reply"):
            try:
                await msg.reply("Упс, что-то сломалось при обработке твоего запроса. Я уже сообщил админу — починим.")
            except Exception:
                pass
    except Exception:
        # error-handler ВНУТРИ error-handler'а — последняя линия защиты
        try:
            print(traceback.format_exc(), flush=True)
        except Exception:
            pass

    return True  # помечаем как обработанную

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
        pass
