async def git_status_handler(msg: Message):
    if not await db_is_admin(msg.from_user.id):
        return await msg.answer("⛔ Только админ.")
    if not _is_git_repo():
        return await msg.answer("❌ Не git-репо.")
    rc1, head_sha, _ = await _run_cmd(["git", "rev-parse", "HEAD"], cwd=str(ROOT), timeout=10)
    rc2, head_msg, _ = await _run_cmd(["git", "log", "-1", "--format=%h %s (%an, %ar)"], cwd=str(ROOT), timeout=10)
    await _run_cmd(["git", "fetch", "origin"], cwd=str(ROOT), timeout=30)
    rc3, ahead_behind, _ = await _run_cmd(
        ["git", "rev-list", "--left-right", "--count", "HEAD...origin/main"],
        cwd=str(ROOT), timeout=10,
    )
    rc4, status, _ = await _run_cmd(["git", "status", "--short"], cwd=str(ROOT), timeout=10)
    ahead, behind = "?", "?"
    if rc3 == 0 and ahead_behind.strip():
        parts = ahead_behind.strip().split()
        if len(parts) == 2:
            ahead, behind = parts[0], parts[1]
    out = (
        f"📦 <b>Git status</b>\n"
        f"HEAD: <code>{head_msg.strip()[:120]}</code>\n"
        f"Ahead: {ahead} / Behind: {behind} (vs origin/main)\n"
        f"Dirty files:\n<pre>{(status.strip() or '(чисто)')[:1200]}</pre>"
    )
    await msg.answer(out)


