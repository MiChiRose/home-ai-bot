# Добавки в .env для P2 (tool calling)
# Скопируй эти строки в свой ~/ai-assistant/.env и заполни.
# llm_loop.py сам подхватит модель из твоих существующих MODEL_ROUTER/MODEL_INSTRUCT —
# отдельно OLLAMA_MODEL ставить НЕ нужно (но можешь переопределить через TOOLS_MODEL).

# ── Ollama (URL уже скорее всего стандартный, оставь если не меняешь) ──
OLLAMA_URL=http://127.0.0.1:11434

# ── Tool calling ──────────────────────────────────────────────────────
MAX_TOOL_ITERATIONS=5
BOT_SANDBOX=/home/linuxserver/bot-workspace

# (опционально) если хочешь для tool-loop использовать модель отличную от MODEL_ROUTER/MODEL_INSTRUCT:
# TOOLS_MODEL=gemma4:e4b

# ── Web search ────────────────────────────────────────────────────────
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=tvly-...                 # https://tavily.com → Dashboard → API Keys (free 1000/мес)
